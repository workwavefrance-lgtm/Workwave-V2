# Supabase — récupérer depuis Project Settings > API sur supabase.com
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URL du site
NEXT_PUBLIC_BASE_URL=https://workwave.fr

# Anthropic (Claude) — qualification IA des projets
ANTHROPIC_API_KEY=your-anthropic-api-key

# Resend — emails transactionnels
RESEND_API_KEY=your-resend-api-key

# Admin — email pour les notifications
ADMIN_EMAIL=admin@workwave.fr

# Stripe — paiements et abonnements
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_MONTHLY_ID=price_xxx
STRIPE_PRICE_ANNUAL_ID=price_xxx
